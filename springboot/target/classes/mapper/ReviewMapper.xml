<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springboot.mapper.ReviewMapper">

    <!-- 结果映射：评价+用户信息 -->
    <resultMap id="ReviewWithUserMap" type="com.example.springboot.entity.ProductReview">
        <id column="id" property="id"/>
        <result column="product_id" property="productId"/>
        <result column="user_id" property="userId"/>
        <result column="order_id" property="orderId"/>
        <result column="score" property="score"/>
        <result column="content" property="content"/>
        <result column="is_admin_reply" property="isAdminReply"/>
        <result column="admin_reply_content" property="adminReplyContent"/>
        <result column="admin_reply_time" property="adminReplyTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
        <!-- 关联用户字段 -->
        <result column="username" property="username"/>
        <result column="userAvatar" property="userAvatar"/>
    </resultMap>

    <!-- 
        根据商品ID查询所有评价（包含用户信息）
        按时间倒序排列
    -->
    <select id="selectReviewsWithUserByProductId" resultMap="ReviewWithUserMap">
        SELECT 
            r.id,
            r.product_id,
            r.user_id,
            r.order_id,
            r.score,
            r.content,
            r.is_admin_reply,
            r.admin_reply_content,
            r.admin_reply_time,
            r.create_time,
            r.update_time,
            r.is_deleted,
            u.username,
            u.avatar as userAvatar
        FROM product_review r
        LEFT JOIN user u ON r.user_id = u.id
        WHERE r.product_id = #{productId}
          AND r.is_deleted = 0
        ORDER BY r.create_time DESC
    </select>

    <!-- 
        查询用户是否已评价过某订单的商品
    -->
    <select id="selectByUserAndOrder" resultType="com.example.springboot.entity.ProductReview">
        SELECT * FROM product_review
        WHERE user_id = #{userId}
          AND order_id = #{orderId}
          AND product_id = #{productId}
          AND is_deleted = 0
        LIMIT 1
    </select>

    <!-- 
        查询某商品的评价数量
    -->
    <select id="countByProductId" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM product_review
        WHERE product_id = #{productId} 
          AND is_deleted = 0
    </select>

    <!-- 
        查询某商品的平均评分
    -->
    <select id="selectAvgScoreByProductId" resultType="java.lang.Double">
        SELECT AVG(score) FROM product_review
        WHERE product_id = #{productId} 
          AND is_deleted = 0
    </select>

    <!-- 
        插入评价记录
    -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product_review (
            product_id,
            user_id,
            order_id,
            score,
            content,
            is_admin_reply,
            create_time,
            update_time,
            is_deleted
        ) VALUES (
            #{productId},
            #{userId},
            #{orderId},
            #{score},
            #{content},
            0,
            NOW(),
            NOW(),
            0
        )
    </insert>

    <!-- 
        逻辑删除评价
    -->
    <update id="deleteById">
        UPDATE product_review 
        SET is_deleted = 1, update_time = NOW()
        WHERE id = #{id}
    </update>

</mapper>
