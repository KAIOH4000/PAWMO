<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springboot.mapper.GoodsMapper">

    <select id="selectTimes" resultType="com.example.springboot.entity.Goods">
        SELECT * FROM goods ORDER BY create_time DESC LIMIT 8
    </select>

    <select id="selectSales" resultType="com.example.springboot.entity.Goods">
        SELECT * FROM goods ORDER BY sales DESC LIMIT 8
    </select>

</mapper>
